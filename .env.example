# --- Database ---
DATABASE_URL="postgresql://taskora:taskora@localhost:5432/taskora?schema=public"

# --- Redis ---
REDIS_HOST="localhost"
REDIS_PORT="6379"

# --- Auth ---
JWT_SECRET="change-me-in-production-please-use-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- AI (المرحلة 5) ---
# لازم مفتاح حقيقي من https://console.anthropic.com عشان توليد الكروت والشات يشتغلوا.
ANTHROPIC_API_KEY=""

# --- Secrets Manager (المرحلة 8) ---
# سرّ تشفير بيانات الاعتماد (Credentials) بـ AES-256-GCM. غيّره في الإنتاج.
TASKORA_ENCRYPTION_KEY="change-me-in-production-please-use-a-long-random-string"

# --- API ---
API_PORT="4000"
API_CORS_ORIGIN="http://localhost:3000"

# --- Web ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
