{
  "name": "taskora",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @taskora/api prisma:generate",
    "db:migrate": "pnpm --filter @taskora/api prisma:migrate",
    "db:studio": "pnpm --filter @taskora/api prisma:studio",
    "db:seed": "pnpm --filter @taskora/api prisma:seed",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
